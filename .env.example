# =================================
# CONFIGURACIÓN DEL ENTORNO
# =================================

# Entorno de ejecución (development, production, test)
NODE_ENV=development

# Puerto del servidor
PORT=3000

# URL base del servidor
URL=http://localhost

# =================================
# BASE DE DATOS
# =================================

# URL de conexion opcional (tiene prioridad sobre DB_HOST/DB_PORT/DB_USER/DB_PASSWORD)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/api_template

# Conexion por campos
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=api_template
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public

# Opciones de Sequelize
DB_SSL=false
DB_SYNC=true
DB_LOGGING=false

# =================================
# AUTENTICACIÓN JWT
# =================================

# Secreto para firmar tokens JWT (mínimo 32 caracteres)
JWT_SECRET=tu-secreto-jwt-muy-seguro-de-al-menos-32-caracteres-aqui

# Tiempo de expiración del token
JWT_EXPIRES_IN=7d

# Días de expiración para cookies
JWT_COOKIE_EXPIRES_IN=7

# =================================
# PAGINACIÓN
# =================================

# Tamaño de página por defecto
PAGINATION_DEFAULT_PAGE_SIZE=20

# Nombre del parámetro de página
PAGINATION_PAGE_ATTR=_page

# Nombre del parámetro de límite
PAGINATION_LIMIT_ATTR=_limit

# Nombre del parámetro de orden
PAGINATION_ORDER_ATTR=_order

# Para ordenar usar _order con campos separados por coma
# Ejemplos: _order="name", _order="-createdAt", _order="name,-createdAt"

# =================================
# LOGGING
# =================================

# Nivel de logging (error, warn, info, http, debug)
LOG_LEVEL=debug

# =================================
# RATE LIMITING
# =================================

# Ventana de tiempo para rate limiting (en milisegundos)
RATE_LIMIT_WINDOW_MS=900000

# Máximo número de requests por ventana
RATE_LIMIT_MAX_REQUESTS=100
